# ============================================================
# DevFolio — Environment Variables
# Copy this file to .env and fill in real values.
# Never commit .env to version control.
# ============================================================

# ── App ──────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001

# ── Database ─────────────────────────────────────────────────
DATABASE_URL=postgresql://devfolio:devfolio@localhost:5432/devfolio
# Set to true when connecting to a managed PostgreSQL that requires SSL (e.g. Supabase, RDS)
DATABASE_SSL=false

# ── Redis ────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379

# ── JWT ──────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_ME_64_CHAR_HEX_SECRET
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=CHANGE_ME_DIFFERENT_64_CHAR_HEX_SECRET
JWT_REFRESH_EXPIRES_IN=30d

# ── Analytics ─────────────────────────────────────────────────
# Salt for one-way IP hashing (required in production).
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
IP_HASH_SALT=CHANGE_ME_32_CHAR_HEX_SALT

# ── Encryption ────────────────────────────────────────────────
# AES-256-GCM key for encrypting sensitive values at rest (GitHub tokens, etc.)
# Required in production. Must be exactly 64 hex characters (32 bytes).
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=CHANGE_ME_64_CHAR_HEX_KEY

# ── GitHub OAuth ──────────────────────────────────────────────
# Create at: https://github.com/settings/developers → New OAuth App
# Homepage URL:     http://localhost:3000
# Callback URL:     http://localhost:3001/api/v1/auth/github/callback
GITHUB_CLIENT_ID=CHANGE_ME
GITHUB_CLIENT_SECRET=CHANGE_ME
GITHUB_CALLBACK_URL=http://localhost:3001/api/v1/auth/github/callback

# ── Storage ───────────────────────────────────────────────────
STORAGE_PROVIDER=local
STORAGE_LOCAL_PATH=./uploads
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
AWS_REGION=us-east-1

# ── Email (Resend) ────────────────────────────────────────────
# Sign up at: https://resend.com — free tier is 100 emails/day
RESEND_API_KEY=CHANGE_ME
NOTIFICATION_FROM_EMAIL=noreply@yourdomain.com
NOTIFICATION_EMAIL_ENABLED=true

# ── Frontend ──────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_APP_URL=http://localhost:3000
